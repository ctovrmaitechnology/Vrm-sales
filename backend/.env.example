PORT=5002
NODE_ENV=production

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
UNIFIED_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# Public URLs
# Must point to the deployed Express backend for email click tracking.
BACKEND_BASE_URL=https://api.example.com
FRONTEND_BASE_URL=https://example.com

# Email
SENDER_EMAIL=contactus@example.com
BREVO_API_KEY=replace_me
ENABLE_UNSUBSCRIBE_HEADERS=true

# Poster / click tracking redirect target
POSTER_URL=https://drive.google.com/file/d/replace_me/view?usp=drive_link

# WhatsApp
ENABLE_WHATSAPP=false
WHATSAPP_TOKEN=replace_me
PHONE_NUMBER_ID=replace_me
WHATSAPP_TEMPLATE_WORKFLOW_AI=techhiring_v3

# Optional integrations
LINKEDIN_BACKEND_URL=http://localhost:3000
