  try {
    res.json(await getUnifiedWhatsAppDashboard());
  } catch (error) {
    res.status(500).json({
      error: "WhatsApp Dashboard fetch failed"
    });
  }
});

app.delete('/api/lead/:email', async (req, res) => {
  const email = req.params.email;

  try {
      const deletedLead = await getLeadByEmail(email);
      if (!deletedLead) {
        const notFoundError = new Error("Lead not found");
        notFoundError.code = 'P2025';
        throw notFoundError;
      }
      await updateLeadFields(email, { source: "deleted", status: "deleted" });
      await updateUnifiedLeadStatus(deletedLead, "email", "deleted", "lead_deleted", {
        source: "deleted"
      });

    res.json({
      success: true,
      message: "Lead deleted successfully",
      lead: deletedLead
    });

  } catch (error) {
    if (error.code === 'P2025') {
      res.status(404).json({
        error: "Lead not found"
      });
    } else {
      res.status(500).json({
        error: "Failed to delete lead"
      });
    }
  }
});

app.post('/api/contact', async (req, res) => {
  try {
    console.log("Contact form received:", req.body);

    return res.status(200).json({
      success: true,
      message: "Message received successfully"
    });

  } catch (error) {
    console.log(error);

    return res.status(500).json({
      success: false,
      message: "Server error"
    });
  }
});

let lastFollowUpDbWarningAt = 0;

cron.schedule('* * * * *', async () => { // TEMPORARY TESTING MODE - Revert back to '0 10 * * *' for production
  console.log("Checking follow-up emails...");

  try {
    try {
      await prisma.$queryRaw`SELECT 1`;
    } catch (dbError) {
      const nowMs = Date.now();
      if (nowMs - lastFollowUpDbWarningAt > 5 * 60 * 1000) {
        console.log(
          "Follow-up cron skipped: database unavailable at localhost:5432"
        );
        lastFollowUpDbWarningAt = nowMs;
      }
      return;
    }

    const now = new Date();

    // Find users who received initial email but haven't clicked
    const followUpUsers = await getFollowUpLeads();

    for (let user of followUpUsers) {
      // TEMPORARY TESTING MODE: Revert back to days for production: (1000 * 60 * 60 * 24)
      const timeSinceInitial = now - new Date(user.initialEmailSentAt);

      let sendFollowUp = null;

      // Day 3 Follow-up (Testing: 1 minute -> 1 * 60 * 1000)
      if (!user.followUp1Sent && timeSinceInitial >= (1 * 60 * 1000)) {
        sendFollowUp = "1";
      }
      // Day 7 Follow-up (Testing: 2 minutes -> 2 * 60 * 1000)
      else if (user.followUp1Sent && !user.followUp2Sent && timeSinceInitial >= (2 * 60 * 1000)) {
        sendFollowUp = "2";
      }

      if (!sendFollowUp) {
        continue;
      }

      try {
        let brevoResult;

        if (sendFollowUp === "1") {
          brevoResult = await sendFollowUp1(user);
          await updateUnifiedLeadStatus(user, "email", "sent", "follow_up_1_sent", {
            messageId: brevoResult?.messageId || null
          });

          if (isWhatsAppEnabled()) {
            await delay(2000);
            await sendWhatsAppFollowUp(user, 1, detectIndustry(user.email));
          } else {
            logWhatsAppDisabled();
          }
        } else if (sendFollowUp === "2") {
          brevoResult = await sendFollowUp2(user);
          await updateUnifiedLeadStatus(user, "email", "sent", "follow_up_2_sent", {
            messageId: brevoResult?.messageId || null
          });

          if (isWhatsAppEnabled()) {
            await delay(2000);
            await sendWhatsAppFollowUp(user, 2, detectIndustry(user.email));
          } else {
            logWhatsAppDisabled();
          }
        }

        console.log(
          `Follow-up ${sendFollowUp} sent to ${user.email} (Message ID: ${brevoResult?.messageId || "accepted"})`
        );

        const randomDelay = randomDelayMs(3, 5);
        await delay(randomDelay);

      } catch (error) {
        console.log(
          `Follow-up ${sendFollowUp} failed for ${user.email}: ${error.message}`
        );
      }
    }

  } catch (error) {
    console.log(
      "Follow-up cron error:",
      error.message
    );
  }
});

